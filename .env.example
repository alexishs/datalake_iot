# =============================================================================
#  Variables d'environnement — copier en .env et adapter (NE PAS commiter .env)
#    cp .env.example .env
#  Les valeurs ci-dessous sont des valeurs de DÉMO LOCALE uniquement.
# =============================================================================

# --- Versions (garder server et ingestion OpenMetadata identiques) ---
AIRFLOW_VERSION=2.9.3
OM_VERSION=1.5.6
ES_VERSION=8.11.4

# --- UID/GID hôte (évite les fichiers root/50000 dans les bind mounts) ---
# IMPORTANT : régler sur la sortie de `id -u` et `id -g` de VOTRE machine.
#   echo "AIRFLOW_UID=$(id -u)"  ;  echo "HOST_UID=$(id -u)"  ;  echo "HOST_GID=$(id -g)"
AIRFLOW_UID=50000
HOST_UID=1000
HOST_GID=1000

# --- Postgres (super-utilisateur du conteneur) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres

# --- Base de l'Airflow métier ---
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me-airflow
# Compte admin de l'UI Airflow (http://localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-admin

# --- Base de l'Airflow interne d'OpenMetadata ---
OM_AIRFLOW_DB=om_airflow
OM_AIRFLOW_DB_USER=om_airflow
OM_AIRFLOW_DB_PASSWORD=change-me-om-airflow

# --- Base du catalogue OpenMetadata ---
OM_DB=openmetadata
OM_DB_USER=openmetadata
OM_DB_PASSWORD=change-me-om

# --- MinIO (console http://localhost:9001, API http://localhost:9000) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# --- Comptes de service MinIO (policies différenciées par bucket, cf. C19/C21) ---
# Créés par le job minio-init. Le mot de passe (secret key) doit faire ≥ 8 caractères.
MINIO_ANALYST_USER=data-analyst
MINIO_ANALYST_PASSWORD=change-me-analyst
MINIO_ENGINEER_USER=data-engineer
MINIO_ENGINEER_PASSWORD=change-me-engineer
MINIO_ADMIN_USER=datalake-admin
MINIO_ADMIN_PASSWORD=change-me-mgr-admin
